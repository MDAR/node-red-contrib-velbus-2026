      "velbus-pir": "nodes/velbus-pir/velbus-pir.js",
      "velbus-pir-20": "nodes/velbus-pir-20/velbus-pir-20.js",
      "velbus-meteo": "nodes/velbus-meteo/velbus-meteo.js",
